# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/doom-wen-bot

# Owner Configuration (hardcoded override for all servers)
OWNER_ID=your_discord_user_id_here

# GitHub Pages Transcript Hosting
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=your-username/your-transcript-repo
GITHUB_BRANCH=main
TRANSCRIPT_BASE_URL=https://your-username.github.io/your-transcript-repo

# BuiltByBit Configuration (single profile)
BUILTBYBIT_PROFILE_ID=your_profile_id_here
BUILTBYBIT_API_KEY=your_api_key_here

# YouTube Configuration
YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here
YOUTUBE_API_KEY=your_youtube_api_key_here
